generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Club {
  id             String   @id @default(uuid())
  name           String
  slug           String
  logoUrl        String?
  primaryColor   String   @default("#000000")
  secondaryColor String?
  iban           String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clubUsers      ClubUser[]
  members        Member[]
  products       Product[]
  forms          Form[]
  fittingDays    FittingDay[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String

  clubUsers ClubUser[]
  
  createdAt DateTime @default(now())
}

model ClubUser {
  id     String       @id @default(uuid())
  role   ClubUserRole @default(ADMIN)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  sku         String?
  
  defaultPrice Float
  sizes        String[]

  clubId      String
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt

  includedInForms FormItem[]
  orderedItems    OrderItem[]
}

model Form {
  id          String   @id @default(uuid())
  name        String
  targetGroups String[]
  isActive    Boolean  @default(true)

  clubId      String
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt

  items       FormItem[]
}

model FormItem {
  id                   String   @id @default(uuid())
  type                 ItemType @default(BASIC)
  includedInBasicCount Int      @default(0)
  customPrice          Decimal? @db.Decimal(10, 2)
  isRequired           Boolean  @default(false)

  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@unique([formId, productId])
}

model Member {
  id            String      @id @default(uuid())
  firstName     String
  lastName      String
  email         String
  group         String
  orderToken    String?     @unique
  hasPaid       Boolean     @default(false)
  
  clubId        String
  club          Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  orders        Order[]

  fittingDayId  String?
  fittingDay    FittingDay?  @relation(fields: [fittingDayId], references: [id])

  createdAt     DateTime?     @default(now())
  updatedAt     DateTime?     @updatedAt
}

model FittingDay {
  id        String   @id @default(uuid())
  date      DateTime
  startTime String
  endTime   String
  location  String?
  reminderSent Boolean @default(false)
  targetGroups String[]
  
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  orders    Order[]
  members   Member[]
}

model Order {
  id          String      @id @default(uuid())
  orderNumber Int         @default(autoincrement())
  status      OrderStatus @default(PENDING)
  totalPrice  Decimal     @default(0.00) @db.Decimal(10, 2)
  
  createdAt   DateTime    @default(now())

  memberId    String
  member      Member      @relation(fields: [memberId], references: [id])
  
  fittingDayId String?
  fittingDay   FittingDay? @relation(fields: [fittingDayId], references: [id])

  items       OrderItem[]
}

model OrderItem {
  id        String   @id @default(uuid())
  size      String
  quantity  Int      @default(1)
  price     Decimal  @db.Decimal(10, 2)

  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum ClubUserRole {
  OWNER
  ADMIN
  MEMBER
}

enum ItemType {
  BASIC
  EXTRA
}

enum OrderStatus {
  PENDING
  CONFIRMED
  ORDERED
  RECEIVED
  DELIVERED
}